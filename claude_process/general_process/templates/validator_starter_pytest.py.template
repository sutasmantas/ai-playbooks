#!/usr/bin/env python3
"""
TEMPLATE METADATA — REMOVE THIS BLOCK WHEN GENERATING
Target: <new-project-root>/scripts/validate_state.py
Generated when the project has a Python toolchain (pyproject.toml / requirements.txt / setup.py).
Placeholders the agent fills in from interview answers + stack detection:
  {{BEHAVIOR_INVOCATION}}  — from interview 02.4. Concrete command/function call that produces a `result`
                             variable, e.g., `result = subprocess.run(['./mycli', '--list'], capture_output=True, text=True)`
  {{BEHAVIOR_ASSERTION}}   — from interview 02.4. What `result` must satisfy, e.g.,
                             `assert 'expected output' in result.stdout`
  {{TYPECHECK_CMD}}         — AGENT-DERIVED from stack detection (ENTRYPOINT Step 4): inspect the project for
                             typechecker config and fill with the matching invocation, OR `None` if no
                             typechecker is configured.
                               - `mypy.ini` present, or `[tool.mypy]` in pyproject.toml → `['mypy', '.']`
                               - `pyrightconfig.json` or `[tool.pyright]` in pyproject.toml → `['pyright']`
                               - `[tool.pyrefly]` / `pyrefly.toml` → `['pyrefly', 'check']`
                               - none of the above → `None` (the typecheck step is skipped)

ESCAPING (important): the agent must produce VALID Python in the placeholder substitutions.
Quotes inside f-strings must be escaped; multi-line code blocks must indent correctly.
Run with: python scripts/validate_state.py
"""

from __future__ import annotations
import json
import os
import re
import subprocess
import sys
from pathlib import Path

ARTIFACT_DIR = Path('diagnostics')
ARTIFACT_DIR.mkdir(exist_ok=True)

failed = False


def assert_behavior() -> bool:
    """Derived from interview 02.4 — the concrete user-visible behavior.

    {{BEHAVIOR_INVOCATION}} must produce a `result` variable (subprocess.CompletedProcess,
    library return value, HTTP response object, etc.). {{BEHAVIOR_ASSERTION}} asserts on `result`.
    The result is written to diagnostics/behavior.log so the tier-2 auditor can read it.
    """
    log_path = ARTIFACT_DIR / 'behavior.log'
    try:
        # {{BEHAVIOR_INVOCATION}}
        # Example: result = subprocess.run(['./mycli', '--list'], capture_output=True, text=True)
        # {{BEHAVIOR_ASSERTION}}
        # Example: assert 'expected output' in result.stdout
        log_path.write_text(f'[behavior] OK\nresult: {result!r}\n')
        print('[behavior] OK')
        return True
    except AssertionError as e:
        log_path.write_text(f'[behavior] FAIL: {e}\n')
        print(f'[behavior] FAIL: {e}', file=sys.stderr)
        return False
    except NameError as e:
        log_path.write_text(f'[behavior] FAIL: {{BEHAVIOR_INVOCATION}} did not produce a `result` variable: {e}\n')
        print(f'[behavior] FAIL: {e}', file=sys.stderr)
        return False
    except Exception as e:
        log_path.write_text(f'[behavior] FAIL (unexpected): {e}\n')
        print(f'[behavior] FAIL (unexpected): {e}', file=sys.stderr)
        return False


def run_tests() -> bool:
    """Run the project's pytest suite. Tests are part of the truth surface."""
    if not (Path('pyproject.toml').exists() or Path('setup.py').exists() or Path('tests').exists()):
        print('[tests] skipped: no pyproject/setup/tests directory found')
        (ARTIFACT_DIR / 'tests.log').write_text('(skipped: no project markers)')
        return True
    proc = subprocess.run(
        ['pytest', '--tb=short', '-q', '--json-report', f'--json-report-file={ARTIFACT_DIR}/tests.json'],
        capture_output=True, text=True
    )
    (ARTIFACT_DIR / 'tests.log').write_text(proc.stdout + proc.stderr)
    if proc.returncode == 0:
        print('[tests] OK')
        return True
    print(f'[tests] FAIL: exit {proc.returncode} — see {ARTIFACT_DIR}/tests.log', file=sys.stderr)
    return False


def capture_typecheck() -> None:
    """Tier-1-does-the-work: run mypy/pyright so the tier-2 auditor (Read/Grep/Glob only)
    can read structured output for check #13 (library/API existence — hallucinated imports)."""
    cmd = {{TYPECHECK_CMD}}  # e.g., ['mypy', '.'] or ['pyright']; None if not configured
    if cmd is None:
        (ARTIFACT_DIR / 'typecheck.log').write_text('(skipped: no typechecker configured)')
        print('[typecheck] skipped')
        return
    proc = subprocess.run(cmd, capture_output=True, text=True)
    (ARTIFACT_DIR / 'typecheck.log').write_text(proc.stdout + proc.stderr)
    if proc.returncode == 0:
        print('[typecheck] OK')
    else:
        print(f'[typecheck] FAIL: see {ARTIFACT_DIR}/typecheck.log', file=sys.stderr)


def capture_git_diff() -> None:
    """Auditor reads this for trivial-diff threshold (≤20 LoC, ≤2 files, etc.)."""
    try:
        files = subprocess.check_output(['git', 'diff', '--name-only', 'HEAD'], text=True).split('\n')
        files = [f for f in files if f]
        numstat = subprocess.check_output(['git', 'diff', '--numstat', 'HEAD'], text=True).strip().split('\n')
        total_loc = sum(
            int(parts[0]) + int(parts[1])
            for line in numstat if line for parts in [line.split('\t')]
            if parts[0].isdigit() and parts[1].isdigit()
        )
        summary = {
            'available': True,
            'total_loc': total_loc,
            'file_count': len(files),
            'files': files,
            'only_markdown': len(files) > 0 and all(f.endswith('.md') for f in files),
        }
    except (subprocess.CalledProcessError, FileNotFoundError):
        summary = {'available': False, 'reason': 'not a git repo or no diff vs HEAD'}
    (ARTIFACT_DIR / 'diff_summary.json').write_text(json.dumps(summary, indent=2))
    if summary.get('available'):
        print(f'[diff] saved diff_summary.json ({summary["total_loc"]} LoC across {summary["file_count"]} files)')
    else:
        print(f'[diff] WARN: {summary["reason"]}')


def capture_dep_check() -> None:
    """Auditor reads this for check #12 (lockfile discipline + slopsquatting).
    A declared dep without lockfile presence is a slopsquat risk or forgotten install."""
    declared: list[str] = []
    pyproject = Path('pyproject.toml')
    requirements = Path('requirements.txt')

    if pyproject.exists():
        # Simple regex extraction; full TOML parsing avoided to keep the starter portable.
        text = pyproject.read_text()
        deps_block = re.search(r'dependencies\s*=\s*\[(.*?)\]', text, re.DOTALL)
        if deps_block:
            declared = re.findall(r'"([^"<>=!~\s]+)', deps_block.group(1))
    elif requirements.exists():
        for line in requirements.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith('#'):
                declared.append(re.split(r'[<>=!~\s]', line)[0])

    lock_entries: set[str] = set()
    for lock_name in ('uv.lock', 'poetry.lock', 'Pipfile.lock'):
        lock_path = Path(lock_name)
        if lock_path.exists():
            lock_text = lock_path.read_text()
            for d in declared:
                escaped = re.escape(d)
                if re.search(rf'(?m)^\s*name\s*=\s*"{escaped}"', lock_text):
                    lock_entries.add(d)
            break

    unlocked = [d for d in declared if d not in lock_entries] if lock_entries else []
    summary = {
        'available': bool(declared),
        'declared_count': len(declared),
        'unlocked_deps': unlocked,
        'unlocked_count': len(unlocked),
    }
    (ARTIFACT_DIR / 'dep_check.json').write_text(json.dumps(summary, indent=2))
    if unlocked:
        print(f'[deps] WARN: {len(unlocked)} dep(s) declared but not in lockfile: {", ".join(unlocked)}', file=sys.stderr)
    elif declared:
        print(f'[deps] OK: all {len(declared)} declared deps present in lockfile')
    else:
        print('[deps] skipped: no pyproject.toml or requirements.txt')


# Secret-pattern scan over source files. Patterns from gitleaks / TruffleHog.
SECRET_PATTERNS = [
    ('AWS Access Key',    re.compile(r'AKIA[0-9A-Z]{16}')),
    ('Stripe Live Key',   re.compile(r'sk_live_[0-9a-zA-Z]{24,}')),
    ('OpenAI Key',        re.compile(r'sk-(proj-)?[A-Za-z0-9_-]{40,}')),
    ('GitHub Token',      re.compile(r'gh[pousr]_[A-Za-z0-9]{36,}')),
    ('Slack Token',       re.compile(r'xox[abprs]-[A-Za-z0-9-]{10,}')),
    ('Private Key Block', re.compile(r'-----BEGIN (RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----')),
    ('Google API Key',    re.compile(r'AIza[0-9A-Za-z_-]{35}')),
]
SCAN_EXTENSIONS = {'.py', '.toml', '.cfg', '.ini', '.env', '.yml', '.yaml', '.json', '.md', '.txt'}
SCAN_SKIP_DIRS = {'.git', '.venv', 'venv', '__pycache__', 'node_modules', 'dist', 'build', ARTIFACT_DIR.name}


def scan_for_secrets() -> list[str]:
    findings = []
    for path in Path('.').rglob('*'):
        if not path.is_file():
            continue
        if any(part in SCAN_SKIP_DIRS for part in path.parts):
            continue
        if path.suffix not in SCAN_EXTENSIONS:
            continue
        try:
            content = path.read_text(errors='ignore')
        except (OSError, UnicodeDecodeError):
            continue
        for name, pat in SECRET_PATTERNS:
            m = pat.search(content)
            if m:
                findings.append(f'{name} in {path}: {m.group(0)[:20]}...')
    return findings


def main() -> None:
    global failed

    if not assert_behavior():
        failed = True
    if not run_tests():
        failed = True

    capture_typecheck()
    capture_git_diff()
    capture_dep_check()

    findings = scan_for_secrets()
    (ARTIFACT_DIR / 'secrets.json').write_text(json.dumps(findings, indent=2))
    if findings:
        print(f'[secrets] FAIL: {len(findings)} match(es):', file=sys.stderr)
        for f in findings:
            print(f'  {f}', file=sys.stderr)
        failed = True
    else:
        print('[secrets] OK: no known patterns in source files')

    sys.exit(1 if failed else 0)


if __name__ == '__main__':
    main()
