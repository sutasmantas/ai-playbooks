#!/usr/bin/env bash
# TEMPLATE METADATA — REMOVE THIS BLOCK WHEN GENERATING
# Target: <new-project-root>/scripts/validate_state.sh
# Generated when the project has a Go toolchain (go.mod present).
# Placeholders the agent fills in from interview answers:
#   {{BEHAVIOR_INVOCATION}}  — concrete command/code that exercises the truth surface, e.g.,
#                              `./mybin --list`  OR  inline `go run` with sample args
#   {{BEHAVIOR_ASSERTION}}    — what the output must contain, e.g.,
#                              `expected_substring` (used by grep -F below)
#
# ESCAPING: single quotes inside placeholders must be encoded as `'\''`.
# Run with: bash scripts/validate_state.sh

set -uo pipefail

ARTIFACT_DIR="diagnostics"
mkdir -p "$ARTIFACT_DIR"

failed=0

# 1. Behavior assertion — derived from interview 02.4: {{BEHAVIOR_INVOCATION}}
behavior_out=$({{BEHAVIOR_INVOCATION}} 2>&1)
behavior_exit=$?
if [ "$behavior_exit" -ne 0 ]; then
  echo "[behavior] FAIL: invocation exited $behavior_exit"
  failed=1
elif echo "$behavior_out" | grep -qF '{{BEHAVIOR_ASSERTION}}'; then
  echo "[behavior] OK"
else
  echo "[behavior] FAIL: expected substring '{{BEHAVIOR_ASSERTION}}' not in output"
  failed=1
fi
echo "$behavior_out" > "$ARTIFACT_DIR/behavior.log"

# 2. Run the test suite — tests are part of the truth surface.
if [ -f go.mod ]; then
  if go test -json ./... > "$ARTIFACT_DIR/tests.json" 2> "$ARTIFACT_DIR/tests.log"; then
    echo "[tests] OK"
  else
    echo "[tests] FAIL: see $ARTIFACT_DIR/tests.log"
    failed=1
  fi
else
  echo "[tests] skipped: no go.mod"
  echo "(skipped: no go.mod)" > "$ARTIFACT_DIR/tests.log"
fi

# 3. Typecheck — `go vet` + `go build` catch hallucinated imports (check #13).
if [ -f go.mod ]; then
  if go vet ./... > "$ARTIFACT_DIR/typecheck.log" 2>&1 && go build ./... >> "$ARTIFACT_DIR/typecheck.log" 2>&1; then
    echo "[typecheck] OK"
  else
    echo "[typecheck] FAIL: see $ARTIFACT_DIR/typecheck.log"
    failed=1
  fi
else
  echo "(skipped: no go.mod)" > "$ARTIFACT_DIR/typecheck.log"
fi

# 4. Tier-1-does-the-work: git diff summary so tier-2 auditor (Read/Grep/Glob only) can read it.
if git rev-parse --git-dir >/dev/null 2>&1; then
  files=$(git diff --name-only HEAD)
  file_count=$(printf '%s\n' "$files" | grep -c . || true)
  : "${file_count:=0}"
  total_loc=$(git diff --numstat HEAD | awk '{sum += $1 + $2} END {print sum+0}')
  non_md_count=$(printf '%s\n' "$files" | grep -cv '\.md$' || true)
  : "${non_md_count:=0}"
  only_md="false"
  if [ "$file_count" -gt 0 ] && [ "$non_md_count" -eq 0 ]; then only_md="true"; fi
  cat > "$ARTIFACT_DIR/diff_summary.json" <<EOF
{
  "available": true,
  "total_loc": $total_loc,
  "file_count": $file_count,
  "files": [$(echo "$files" | sed 's/.*/"&"/' | paste -sd,)],
  "only_markdown": $only_md
}
EOF
  echo "[diff] saved $ARTIFACT_DIR/diff_summary.json ($total_loc LoC across $file_count files)"
else
  echo '{"available": false, "reason": "not a git repo"}' > "$ARTIFACT_DIR/diff_summary.json"
fi

# 5. Dep check — `go mod tidy -diff` reveals declared-but-unused or missing-from-lockfile deps.
if [ -f go.mod ]; then
  # `go mod verify` checks that modules in the cache match go.sum (lockfile integrity).
  if go mod verify > "$ARTIFACT_DIR/dep_check.log" 2>&1; then
    echo '{"available": true, "verified": true}' > "$ARTIFACT_DIR/dep_check.json"
    echo "[deps] OK: go.sum verified"
  else
    echo '{"available": true, "verified": false}' > "$ARTIFACT_DIR/dep_check.json"
    echo "[deps] FAIL: see $ARTIFACT_DIR/dep_check.log"
    failed=1
  fi
else
  echo '{"available": false, "reason": "no go.mod"}' > "$ARTIFACT_DIR/dep_check.json"
fi

# 6. Secret-pattern scan over source files. Output: diagnostics/secrets.json (JSON array of strings).
# Patterns from gitleaks / TruffleHog. ERE for portability.
PATTERNS=(
  'AKIA[0-9A-Z]{16}'                                          # AWS Access Key
  'sk_live_[0-9a-zA-Z]{24,}'                                  # Stripe Live Key
  'sk-(proj-)?[A-Za-z0-9_-]{40,}'                             # OpenAI Key
  'gh[pousr]_[A-Za-z0-9]{36,}'                                # GitHub Token
  'xox[abprs]-[A-Za-z0-9-]{10,}'                              # Slack Token
  '-----BEGIN (RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----'      # Private Key
  'AIza[0-9A-Za-z_-]{35}'                                     # Google API Key
)
# Restrict to source-shaped files, skip common build/vendor dirs.
mapfile -t scan_files < <(find . -type f \
  \( -name '*.go' -o -name '*.mod' -o -name '*.sum' -o -name '*.yml' -o -name '*.yaml' -o -name '*.json' -o -name '*.md' -o -name '*.env' -o -name '*.txt' \) \
  ! -path './.git/*' ! -path './vendor/*' ! -path "./$ARTIFACT_DIR/*")
# Build a JSON array of findings. File paths in well-behaved repos don't contain quotes/backslashes;
# this is a calibration tool, not user-data ingest — escape if your repo has unusual paths.
secrets_json="["
first=1
SECRET_FOUND=0
for f in "${scan_files[@]}"; do
  for pat in "${PATTERNS[@]}"; do
    if grep -E -l "$pat" "$f" >/dev/null 2>&1; then
      if [ "$first" -eq 1 ]; then first=0; else secrets_json+=","; fi
      secrets_json+="\"match in $f: pattern matched\""
      SECRET_FOUND=1
    fi
  done
done
secrets_json+="]"
echo "$secrets_json" > "$ARTIFACT_DIR/secrets.json"
if [ "$SECRET_FOUND" -eq 0 ]; then
  echo "[secrets] OK: no known patterns in source files"
else
  echo "[secrets] FAIL: see $ARTIFACT_DIR/secrets.json"
  failed=1
fi

exit $failed
